import java.util.Scanner;

{

public class ListaMercado {

  public static void main(String[] args) {

    new ListaMercado();

  }



  public ListaMercado() {

    Scanner scanner = new Scanner(System.in);

    String lista[] = new String[20];

    int qtdItens = 0;



    System.out.println("=== Lista de Compras ===");



    while (qtdItens < 20) {

      System.out.print("Digite o nome do item para comprar: ");

      String item = scanner.nextLine().trim();



      if (item.isEmpty()) {

        System.out.println("Item inválido! Tente novamente.");

        continue;

      }



      boolean existe = false;

      for (int i = 0; i < qtdItens; i++) {

        if (lista[i].equalsIgnoreCase(item)) {

          existe = true;

          break;

        }

      }



      if (existe) {

        System.out.println("Item já está na lista! Não será adicionado.");

      } else {

        

        lista[qtdItens] = item;

        qtdItens++;

        

        ordenar(lista, qtdItens);



        

        System.out.println("Lista atualizada:");

        exibirLista(lista, qtdItens);

      }



      

      if (qtdItens >= 10 && qtdItens < 20) {

        System.out.print("Deseja adicionar mais itens? (S): ");

        String resposta = scanner.nextLine().trim();

        if (resposta.equalsIgnoreCase("N")) {

          break;

        }

      }

    }



    System.out.println("\n=== Lista final de compras ===");

    exibirLista(lista, qtdItens);



    scanner.close();

  }



 

  private void exibirLista(String[] lista, int qtd) {

    for (int i = 0; i < qtd; i++) {

      System.out.print(lista[i] + " || ");

    }

    System.out.println();

  }



  private void ordenar(String[] lista, int qtd) {

    boolean trocou;

    do {

      trocou = false;

      for (int i = 0; i < qtd - 1; i++) {

        if (lista[i].compareToIgnoreCase(lista[i + 1]) > 0) {

          String tmp = lista[i];

          lista[i] = lista[i + 1];

          lista[i + 1] = tmp;

          trocou = true;

        }

      }

    } while (trocou);

  }



